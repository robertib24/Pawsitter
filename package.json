{
  "name": "pawsitter",
  "version": "1.0.0",
  "description": "Platformă de pet sitting — proiect demo Vue 3 + Tailwind + DaisyUI",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm:server\" \"npm:client\"",
